{
  "tasks": {
    "probe": "deno run --allow-env --allow-net --allow-read --allow-write src/main.ts probe",
    "run": "deno run --allow-env --allow-net --allow-read --allow-write src/main.ts run",
    "report": "deno run --allow-read --allow-write src/report.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any"
      ]
    }
  }
}
